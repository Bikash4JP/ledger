# ───────────────────────────────────────────
# MobiLedger — .gitignore
# React Native + Expo + TypeScript
# ───────────────────────────────────────────


# ── Dependencies ────────────────────────────
node_modules/
.pnp
.pnp.js


# ── Expo ────────────────────────────────────
.expo/
.expo-shared/
expo-env.d.ts
dist/
web-build/


# ── Native build outputs ─────────────────────
# (Only relevant if you ever eject / run bare workflow)
android/
ios/
*.orig


# ── EAS / Build artifacts ───────────────────
.easignore
eas-build-pre-install.sh


# ── Metro bundler ───────────────────────────
.metro-health-check*
.packager-info.json


# ── Environment & Secrets ───────────────────
.env
.env.local
.env.*.local
*.pem


# ── Credentials & Keystores ─────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.cer
google-services.json
GoogleService-Info.plist


# ── Logs ────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
logs/


# ── Testing & Coverage ──────────────────────
coverage/
.nyc_output/
junit.xml


# ── TypeScript ──────────────────────────────
*.tsbuildinfo


# ── OS-generated files ──────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini


# ── Editor / IDE ────────────────────────────
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# .vscode/ is intentionally NOT ignored so shared settings are tracked


# ── Temporary files ─────────────────────────
tmp/
temp/
*.tmp
*.bak
*.swp